{
  "name": "mcp-load-test",
  "version": "0.1.0",
  "description": "Load testing framework purpose-built for MCP servers. Transport-aware, session-based, pattern-driven — with latency histograms and breaking point detection.",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "mcp-load-test": "dist/src/cli.js",
    "mcp-lt": "dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "keywords": [
    "mcp",
    "load-test",
    "stress-test",
    "performance",
    "latency",
    "benchmark",
    "cli",
    "profiling",
    "concurrency",
    "transport"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "dev": "npm run build && node --enable-source-maps dist/src/cli.js",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "eventsource": "^4.1.0",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/mcp-load-test.git"
  },
  "homepage": "https://github.com/reaatech/mcp-load-test#readme",
  "bugs": {
    "url": "https://github.com/reaatech/mcp-load-test/issues"
  },
  "files": [
    "dist/src",
    "LICENSE",
    "README.md",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ]
}
