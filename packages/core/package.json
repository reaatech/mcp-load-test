{
  "name": "@reaatech/mcp-load-test-core",
  "version": "0.1.0",
  "description": "Core types, schemas, utilities, and observability for MCP load testing",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/mcp-load-test.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/reaatech/mcp-load-test/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/reaatech/mcp-load-test/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
